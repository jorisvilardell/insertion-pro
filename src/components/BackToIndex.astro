---
// Bouton flottant permanent — retour à l'index
const home = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<a
  href={home}
  aria-label="Retour à l'accueil"
  class="group fixed bottom-6 right-6 z-50 inline-flex items-center gap-2 border-2 border-base-950 bg-rust-600 px-4 py-3 text-sm font-semibold text-white shadow-[4px_4px_0_0_var(--color-base-950)] transition-all duration-150 hover:-translate-x-0.5 hover:-translate-y-0.5 hover:bg-rust-500 hover:shadow-[6px_6px_0_0_var(--color-base-950)]"
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    fill="none"
    viewBox="0 0 24 24"
    stroke-width="1.8"
    stroke="currentColor"
    class="h-5 w-5"
    aria-hidden="true"
  >
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"
    ></path>
  </svg>
  <span class="hidden sm:inline">Index</span>
</a>
