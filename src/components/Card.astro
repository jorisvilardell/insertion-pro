---
import Button from './Button.astro';
import Icon from './Icon.astro';

interface CardLink {
  label: string;
  href: string;
}

interface Props {
  title: string;
  description: string;
  icon: 'map' | 'cycle' | 'rocket';
  index?: string;
  links: CardLink[];
}

const { title, description, icon, index, links } = Astro.props;
---

<article
  class="group flex h-full flex-col border-2 border-base-950 bg-base-800 p-7 shadow-[6px_6px_0_0_var(--color-base-950)] transition-all duration-200 hover:-translate-x-1 hover:-translate-y-1 hover:border-rust-600/50 hover:shadow-[10px_10px_0_0_var(--color-rust-600)]"
>
  <div class="mb-6 flex items-center justify-between">
    <div
      class="inline-flex h-12 w-12 items-center justify-center border-2 border-rust-600/40 bg-rust-600/10 text-rust-500 transition-colors duration-200 group-hover:bg-rust-600 group-hover:text-white"
    >
      <Icon name={icon} class="h-6 w-6" />
    </div>
    {
      index && (
        <span class="font-mono text-sm text-base-700 transition-colors group-hover:text-rust-600/60">
          {index}
        </span>
      )
    }
  </div>

  <h3 class="text-xl font-bold text-white">{title}</h3>
  <p class="mt-3 text-sm leading-relaxed text-slate-400">{description}</p>

  <!-- Supporte un OU plusieurs boutons d'action -->
  <div class="mt-auto flex flex-col gap-3 pt-7">
    {
      links.map((link, i) => (
        <Button href={link.href} variant={i === 0 ? 'primary' : 'secondary'}>
          {link.label}
        </Button>
      ))
    }
  </div>
</article>
