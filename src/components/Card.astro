---
import Button from './Button.astro';
import Icon from './Icon.astro';

interface CardLink {
  label: string;
  href: string;
}

interface Props {
  title: string;
  icon: 'map' | 'cycle' | 'rocket';
  actions: string[];
  links: CardLink[];
}

const { title, icon, actions, links } = Astro.props;
---

<article
  class="group flex h-full flex-col border-2 border-base-950 bg-base-800 p-7 shadow-[6px_6px_0_0_var(--color-base-950)] transition-all duration-200 hover:-translate-x-1 hover:-translate-y-1 hover:border-rust-600/50 hover:shadow-[10px_10px_0_0_var(--color-rust-600)]"
>
  <!-- En-tête : icône + titre + séparateur -->
  <div class="flex items-center gap-3 border-b-2 border-base-950 pb-5">
    <span
      class="inline-flex h-12 w-12 shrink-0 items-center justify-center border-2 border-rust-600/40 bg-rust-600/10 text-rust-500 transition-colors duration-200 group-hover:bg-rust-600 group-hover:text-white"
    >
      <Icon name={icon} class="h-6 w-6" />
    </span>
    <h3 class="text-xl font-bold text-white">{title}</h3>
  </div>

  <!-- Actions concrètes -->
  <ul class="mt-6 space-y-3">
    {
      actions.map((a) => (
        <li class="flex items-start gap-3">
          <span
            class="mt-2 h-1.5 w-1.5 shrink-0 bg-rust-500"
            aria-hidden="true"
          />
          <span class="text-sm leading-snug text-slate-300">{a}</span>
        </li>
      ))
    }
  </ul>

  <!-- Preuves : un OU plusieurs boutons -->
  <div class="mt-auto flex flex-col gap-3 pt-7">
    {
      links.map((link, i) => (
        <Button href={link.href} variant={i === 0 ? 'primary' : 'secondary'}>
          {link.label}
        </Button>
      ))
    }
  </div>
</article>
