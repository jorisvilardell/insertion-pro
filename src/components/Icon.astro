const isFilled = name === 'github';
---

{
  isFilled ? (
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      fill="currentColor"
      class={className}
      aria-hidden="true"
    >
      <path fill-rule="evenodd" clip-rule="evenodd" d={paths[name]} />
    </svg>
  ) : (
    <svg
      xmlns="http://www.w3.org/2000/svg"
      fill="none"
      viewBox="0 0 24 24"
      stroke-width="1.8"
      stroke="currentColor"
      class={className}
      aria-hidden="true"
    >
      <path stroke-linecap="round" stroke-linejoin="round" d={paths[name]} />
    </svg>
  )
}
