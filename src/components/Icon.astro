---
// Icônes SVG inline (heroicons v2). Pas de dépendance externe.
type IconName =
  | 'map'
  | 'cycle'
  | 'rocket'
  | 'arrow'
  | 'github'
  | 'cap'
  | 'wrench'
  | 'server';

interface Props {
  name: IconName;
  class?: string;
}

