---
// Coquille d'une slide plein écran (PowerPoint-like)
interface Props {
  index: number;
  total: number;
  eyebrow?: string;
  id?: string;
}

const { index, total, eyebrow, id } = Astro.props;
const num = String(index).padStart(2, '0');
const tot = String(total).padStart(2, '0');
---

<section
  id={id}
  data-slide
  class="relative flex min-h-screen w-full snap-start flex-col justify-between p-6 sm:p-10 lg:p-12"
>
  <!-- Barre supérieure : partie + compteur -->
  <header class="flex items-center justify-between">
    <span class="font-mono text-xs uppercase tracking-widest text-rust-500 sm:text-sm">
      {eyebrow}
    </span>
    <span class="font-mono text-sm text-slate-600">
      <span class="text-rust-500">{num}</span> / {tot}
    </span>
  </header>

  <!-- Contenu principal -->
  <div class="flex flex-1 items-center py-8">
    <div class="w-full">
      <slot />
    </div>
  </div>

  <!-- Pied de slide -->
  <footer class="flex items-center justify-between font-mono text-xs text-slate-600">
    <span>FerrisKey · Insertion Professionnelle</span>
    <span class="hidden sm:inline">2026</span>
  </footer>
</section>
