---
import Layout from '../layouts/Layout.astro';
import Slide from '../components/slides/Slide.astro';
import SplitSlide from '../components/slides/SplitSlide.astro';
import Bullet from '../components/slides/Bullet.astro';
import Step from '../components/slides/Step.astro';
import Icon from '../components/Icon.astro';
import BackToIndex from '../components/BackToIndex.astro';
import FullscreenButton from '../components/FullscreenButton.astro';

const total = 7;
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');

// Slide "Mon quotidien" — gestion quotidienne (sans image)
const casquettes = [
  {
    icon: 'cap' as const,
    title: 'Alternant',
    items: [
      'Montée en compétences encadrée (école ↔ entreprise)',
      'Rigueur et méthodes appliquées au réel',
      'Jongler entre cours, missions et open source',
    ],
  },
  {
    icon: 'wrench' as const,
    title: 'Mainteneur',
    items: [
      "Triage des issues et revues de PR au fil de l'eau",
      'Suivi de la roadmap et synchronisations hebdomadaires',
      'Garant de la qualité et de la vision du projet',
    ],
  },
  {
    icon: 'server' as const,
    title: 'Entrepreneur',
    items: [
      "Conception d'applications pour les clients",
      'Mise en production de FerrisKey',
      'Remontée des bugs et des besoins',
    ],
    projects: [
      { label: 'alberasolsetenergies.fr', href: 'https://alberasolsetenergies.fr/' },
      {
        label: 'zukquote.alberasolsetenergies.fr',
        href: 'https://zukquote.alberasolsetenergies.fr/',
      },
    ],
  },
];
---

<Layout title="Soutenance — Insertion dans l'Open Source">
  <div
    id="deck"
    class="h-screen w-full snap-y snap-mandatory overflow-y-auto overscroll-y-contain scroll-smooth"
  >
    <!-- ====================== SLIDE 1 — Titre ====================== -->
    <Slide index={1} total={total} eyebrow="Partie 1 · Introduction" id="slide-1">
      <div class="mx-auto max-w-5xl text-center">
        <h1
          class="text-5xl font-extrabold leading-tight tracking-tight text-white sm:text-6xl"
        >
          Insertion dans l'<span class="text-rust-500">Open Source</span>
        </h1>
        <p class="mt-6 text-2xl text-slate-400 sm:text-3xl">
          Restitution d'Action IRL sur le projet FerrisKey
        </p>

        <div class="mx-auto mt-12 max-w-5xl">
          <img
            src={`${base}screens/screen1.png`}
            alt="Logo FerrisKey"
            class="w-full h-auto rounded-xl shadow-2xl border border-slate-700"
          />
        </div>

        <p class="mt-10 font-mono text-sm text-slate-500">
          ↓ Défiler · ou flèches du clavier
        </p>
      </div>
    </Slide>

    <!-- ====================== SLIDE 2 — Casquette Mainteneur ====================== -->
    <SplitSlide
      index={2}
      total={total}
      id="slide-2"
      eyebrow="Partie 2 · La casquette de Mainteneur"
      title="Mon rôle : Mainteneur"
      shape="circle"
      profile={{ label: 'jorisvilardell', href: 'https://github.com/jorisvilardell' }}
      image={{
        src: `${base}avatar.webp`,
        alt: 'Photo de profil',
      }}
    >
      <Bullet>Garant de la santé et de la qualité du dépôt (MCO)</Bullet>
      <Bullet>Triage quotidien : qualifier et prioriser issues &amp; Pull Requests</Bullet>
      <Bullet>Gardien de la vision : aligner les contributions sur la raison d'être du projet</Bullet>
      <Bullet>Animer la communauté : synchronisations hebdomadaires, communication, arbitrages</Bullet>
    </SplitSlide>

    <!-- ====================== SLIDE 3 — Les mécaniques clés ====================== -->
    <SplitSlide
      index={3}
      total={total}
      id="slide-3"
      eyebrow="Partie 2 · Les mécaniques clés"
      title="Le cycle de vie : Roadmap → Issues → PR"
      image={{
        src: `${base}screens/screen4.png`,
        alt: 'Roadmap / GitHub Project de FerrisKey',
      }}
    >
      <Step n="01" title="Roadmap">
        Définir le cap : versions, priorités et vision partagés publiquement.
      </Step>
      <Step n="02" title="Issues">
        Découper et qualifier le travail : bugs, features et refactors balisés.
      </Step>
      <Step n="03" title="Pull Requests">
        Livrer et valider : du code revu, discuté et intégré sans casser l'existant.
      </Step>
    </SplitSlide>

    <!-- ====================== SLIDE 4 — Mon quotidien (sans image) ====================== -->
    <Slide index={4} total={total} eyebrow="Partie 2 · Le quotidien" id="slide-4">
      <div class="mx-auto w-full max-w-6xl">
        <div class="text-center">
          <h2
            class="text-4xl font-extrabold leading-tight tracking-tight text-white sm:text-5xl lg:text-6xl"
          >
            Mon quotidien : trois casquettes
          </h2>
          <div class="mx-auto mt-6 h-1.5 w-20 bg-rust-600"></div>
        </div>

        <div class="mt-12 grid items-stretch gap-6 md:grid-cols-3">
          {
            casquettes.map((c) => (
              <div class="group relative flex flex-col border-2 border-base-950 bg-base-800 p-7 shadow-[6px_6px_0_0_var(--color-base-950)] transition-all duration-200 hover:-translate-y-1 hover:border-rust-600/50 hover:shadow-[8px_8px_0_0_var(--color-rust-600)]">
                <div class="flex items-center gap-3 border-b-2 border-base-950 pb-5">
                  <span class="inline-flex h-12 w-12 shrink-0 items-center justify-center border-2 border-rust-600/40 bg-rust-600/10 text-rust-500 transition-colors duration-200 group-hover:bg-rust-600 group-hover:text-white">
                    <Icon name={c.icon} class="h-6 w-6" />
                  </span>
                  <h3 class="text-xl font-bold text-white lg:text-2xl">{c.title}</h3>
                </div>
                <ul class="mt-6 space-y-4">
                  {c.items.map((it) => (
                    <li class="flex items-start gap-3">
                      <span
                        class="mt-2 h-1.5 w-1.5 shrink-0 bg-rust-500"
                        aria-hidden="true"
                      />
                      <span class="text-base leading-snug text-slate-300 lg:text-lg">
                        {it}
                      </span>
                    </li>
                  ))}
                </ul>

                {
                  c.projects && (
                    <p class="mt-6 flex items-center gap-2 border-t-2 border-base-950 pt-4 font-mono text-xs uppercase tracking-wider text-rust-400">
                      <Icon name="server" class="h-4 w-4" />
                      Survolez : déploiements
                    </p>
                  )
                }

                {
                  c.projects && (
                    <div class="pointer-events-none absolute inset-x-0 top-full z-20 origin-top scale-95 pt-3 opacity-0 transition-all duration-200 group-hover:pointer-events-auto group-hover:scale-100 group-hover:opacity-100">
                      <div class="border-2 border-rust-600 bg-base-950 p-4 shadow-[6px_6px_0_0_var(--color-base-950)]">
                        <p class="flex items-center gap-2 font-mono text-xs uppercase tracking-wider text-rust-400">
                          <Icon name="rocket" class="h-4 w-4" />
                          Déployé en production
                        </p>
                        <ul class="mt-3 space-y-2">
                          {c.projects.map((p) => (
                            <li>
                              <a
                                href={p.href}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="inline-flex items-center gap-2 break-all text-sm text-slate-200 transition-colors hover:text-rust-400"
                              >
                                <span class="h-1.5 w-1.5 shrink-0 bg-rust-500" />
                                {p.label}
                              </a>
                            </li>
                          ))}
                        </ul>
                      </div>
                    </div>
                  )
                }
              </div>
            ))
          }
        </div>

        <p class="mx-auto mt-12 max-w-3xl text-center text-lg text-slate-400 lg:text-xl">
          <span class="font-semibold text-rust-400">Un cercle vertueux</span> : le
          terrain client nourrit la maintenance, qui renforce mes compétences — et
          pousse à la contribution.
        </p>
      </div>
    </Slide>

    <!-- ====================== SLIDE 5 — Onboarding contributeur ====================== -->
    <SplitSlide
      index={5}
      total={total}
      id="slide-5"
      eyebrow="Partie 3 · Accueillir & Outiller"
      title="Onboarding : abaisser la barrière d'entrée"
      image={{
        src: `${base}screens/screen3.png`,
        alt: 'Fichier CONTRIBUTING.md du dépôt FerrisKey',
      }}
    >
      <Bullet><strong class="font-bold text-white">CONTRIBUTING.md</strong> : les règles du jeu (styles, commits, cloner &amp; compiler)</Bullet>
      <Bullet>Documentation technique centralisée (architecture, docs.ferriskey.rs)</Bullet>
      <Bullet>Templates d'issues : un cadre clair pour exprimer un besoin</Bullet>
      <Bullet>Code lisible, typé et testé (CI/CD) → on contribue en confiance</Bullet>
    </SplitSlide>

    <!-- ====================== SLIDE 6 — Casquette Contributeur ====================== -->
    <SplitSlide
      index={6}
      total={total}
      id="slide-6"
      eyebrow="Partie 3 · La casquette de Contributeur"
      title="Devenir Contributeur"
      image={{
        src: `${base}screens/screen8.png`,
        alt: "Synthèse de l'activité et des contributions sur FerrisKey",
      }}
    >
      <Bullet>Pas besoin d'être expert : une première contribution peut être minime</Bullet>
      <Bullet>S'approprier une issue balisée, puis proposer une Pull Request</Bullet>
      <Bullet>Apporter un autre regard : tester, documenter, remonter un bug</Bullet>
      <Bullet>Monter en compétence au contact de la revue et de la communauté</Bullet>
      <Bullet>Chacun fait avancer le projet, à son échelle</Bullet>
    </SplitSlide>

    <!-- ====================== SLIDE 7 — Comment Contribuer ====================== -->
    <SplitSlide
      index={7}
      total={total}
      id="slide-7"
      eyebrow="Partie 4 · Passer à l'action"
      title="Ouvrir la Voie : Comment Contribuer ?"
      image={{
        src: `${base}screens/screen7.png`,
        alt: 'Code source et pipeline CI/CD de FerrisKey',
      }}
    >
      <Bullet>
        <strong class="font-bold text-white">Par le Code :</strong> Ouverture d'une
        Pull Request rigoureuse liée à une Issue validée.
      </Bullet>
      <Bullet>
        <strong class="font-bold text-white">Par la Revue :</strong> Analyser et valider
        le code d'un pair est une contribution à part entière.
      </Bullet>
      <Bullet>
        <strong class="font-bold text-white">Par la Gouvernance :</strong> Ouvrir
        des tickets, participer aux débats techniques, trier et baliser.
      </Bullet>
    </SplitSlide>
  </div>

  <!-- Navigation par points (jump rapide pendant la soutenance) -->
  <nav
    aria-label="Navigation des slides"
    class="fixed right-5 top-1/2 z-50 hidden -translate-y-1/2 flex-col gap-3 lg:flex"
  >
    {
      Array.from({ length: total }).map((_, i) => (
        <a
          href={`#slide-${i + 1}`}
          data-dot={i + 1}
          aria-label={`Aller à la slide ${i + 1}`}
          class="deck-dot h-3 w-3 border-2 border-rust-600/50 transition-all duration-200 hover:border-rust-500 hover:bg-rust-500/40"
        />
      ))
    }
  </nav>

  <!-- Bouton flottant permanent : retour index -->
  <BackToIndex />

  <!-- Bouton plein écran (soutenance) -->
  <FullscreenButton />
</Layout>

<style>
  /* Point de navigation actif (toggle JS) */
  .deck-dot.is-active {
    background-color: #ea580c;
    border-color: #f97316;
    transform: scale(1.3);
  }
</style>

<script>
  const deck = document.getElementById('deck');
  const slides = Array.from(document.querySelectorAll<HTMLElement>('[data-slide]'));
  const dots = Array.from(document.querySelectorAll<HTMLElement>('[data-dot]'));

  if (deck && slides.length) {
    const goTo = (i: number) => {
      const idx = Math.max(0, Math.min(slides.length - 1, i));
      slides[idx]?.scrollIntoView({ behavior: 'smooth' });
    };
    const currentIndex = () => Math.round(deck.scrollTop / window.innerHeight);

    // Navigation clavier (flèches, espace, PageUp/Down, Home/End, F = plein écran)
    window.addEventListener('keydown', (e) => {
      const k = e.key;
      if (k === 'ArrowDown' || k === 'PageDown' || k === ' ') {
        e.preventDefault();
        goTo(currentIndex() + 1);
      } else if (k === 'ArrowUp' || k === 'PageUp') {
        e.preventDefault();
        goTo(currentIndex() - 1);
      } else if (k === 'Home') {
        e.preventDefault();
        goTo(0);
      } else if (k === 'End') {
        e.preventDefault();
        goTo(slides.length - 1);
      } else if (k === 'f' || k === 'F') {
        e.preventDefault();
        document.getElementById('fullscreen-btn')?.click();
      }
    });

    // Mise en évidence du point actif
    const io = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            const i = slides.indexOf(entry.target as HTMLElement);
            dots.forEach((d, di) => d.classList.toggle('is-active', di === i));
          }
        }
      },
      { root: deck, threshold: 0.5 },
    );
    slides.forEach((s) => io.observe(s));
  }
</script>
